# ── Backend (server/index.js) ───────────────────────────────────────────────
# Copy to ".env" for local development. On Railway, set these as service
# variables instead (never commit the real .env — it is gitignored).

# Password for the begeleider/admin console at /admin. REQUIRED to enable admin.
# Use a long, random value. Without it, all admin endpoints return 503.
ADMIN_PASSWORD=change-me-to-a-long-random-secret

# Port the server listens on. Railway sets PORT automatically; leave unset there.
PORT=3001

# Where the JSON state file is stored. On Railway, mount a volume and point this
# at the mount path (e.g. /data) so the data survives redeploys.
# Locally it defaults to ./data when unset.
# DATA_DIR=/data

# Only needed if the front-end is served from a DIFFERENT origin than this API
# (e.g. GitHub Pages). Comma-separated list of allowed origins. Leave empty when
# this server also serves the front-end (same origin).
# CORS_ORIGINS=https://brainstorm2030.nl
